<div class="min-h-screen flex items-center justify-center -mt-28">
  <div class="max-w-md w-full space-y-8">
    <div class="text-center">
      <h1 class="text-3xl font-bold text-slate-900">Consulting CRM</h1>
      <p class="mt-2 text-slate-600">Welcome, <%= current_user.name %>!</p>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-8 text-center">
      <h2 class="text-lg font-semibold text-yellow-800">Waiting for Approval</h2>
      <p class="mt-2 text-yellow-700">
        Your account has been created but an administrator needs to assign you a role before you can access the application.
      </p>
      <p class="mt-4 text-sm text-yellow-600">
        Please contact your team administrator to get access.
      </p>
    </div>

    <div class="text-center">
      <%= button_to "Sign Out", logout_path, method: :delete, class: "text-slate-500 hover:text-slate-700 text-sm" %>
    </div>
  </div>
</div>
