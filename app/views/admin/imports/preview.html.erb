<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Import Preview: <%= @record_type.capitalize.pluralize %></h1>

  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <p class="text-sm text-slate-600">
          <span class="font-semibold text-slate-900"><%= @row_count %></span> rows found in CSV
        </p>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Row</th>
            <% @parsed[:rows].first&.except(:row_number)&.keys&.each do |key| %>
              <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase"><%= key %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @parsed[:rows].first(20).each do |row| %>
            <tr>
              <td class="px-4 py-2 text-sm text-slate-500"><%= row[:row_number] %></td>
              <% row.except(:row_number).each do |_key, value| %>
                <td class="px-4 py-2 text-sm text-slate-900 max-w-xs truncate"><%= value.is_a?(Hash) ? value.values.compact.join(", ") : value %></td>
              <% end %>
            </tr>
          <% end %>
          <% if @parsed[:rows].size > 20 %>
            <tr>
              <td colspan="100" class="px-4 py-2 text-sm text-slate-500 italic">...and <%= @parsed[:rows].size - 20 %> more rows</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= form_with url: admin_imports_path, method: :post, data: { turbo: false } do |f| %>
      <%= f.hidden_field :csv_content, value: @csv_content %>
      <%= f.hidden_field :record_type, value: @record_type %>
      <%= f.submit "Confirm Import", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 cursor-pointer" %>
    <% end %>
    <%= link_to "Cancel", new_admin_import_path, class: "inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-lg text-slate-700 bg-white hover:bg-slate-50" %>
  </div>
</div>
