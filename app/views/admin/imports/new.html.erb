<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Import Data</h1>

  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-lg mb-6">
    <p class="font-semibold mb-1">Import order</p>
    <ol class="list-decimal list-inside text-sm space-y-1">
      <li>Users (consultants and admins)</li>
      <li>Customers</li>
      <li>Proposals (requires existing customers)</li>
    </ol>
    <p class="text-sm mt-2">User imports are additive — duplicate emails are skipped automatically. To re-import customers or proposals, clear existing records via rails console first.</p>
  </div>

  <% if @existing_counts[:customers] > 0 || @existing_counts[:proposals] > 0 %>
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 rounded mb-6">
      <p class="font-semibold mb-1">Existing records detected</p>
      <ul class="text-sm space-y-1">
        <li>Customers: <%= @existing_counts[:customers] %></li>
        <li>Proposals: <%= @existing_counts[:proposals] %></li>
      </ul>
      <p class="text-sm mt-2">If re-importing customers or proposals, clear records first via rails console (e.g., <code class="bg-yellow-100 px-1 rounded">Customer.destroy_all</code>).</p>
    </div>
  <% end %>

  <%= form_with url: preview_admin_imports_path, method: :post, multipart: true, data: { turbo: false }, class: "bg-white ring-1 ring-slate-200 rounded-xl p-6" do |f| %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700 mb-1">Record type</label>
      <select name="record_type" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
        <option value="">Select...</option>
        <% @record_types.each do |label, value| %>
          <option value="<%= value %>"><%= label %></option>
        <% end %>
      </select>
    </div>

    <div class="mb-6">
      <label class="block text-sm font-medium text-slate-700 mb-1">CSV file</label>
      <input type="file" name="file" accept=".csv" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200">
    </div>

    <div>
      <%= f.submit "Preview Import", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-slate-800 hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 cursor-pointer" %>
    </div>
  <% end %>
</div>
