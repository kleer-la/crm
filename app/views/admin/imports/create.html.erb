<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Import Results: <%= @record_type.capitalize.pluralize %></h1>

  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6 mb-6">
    <dl class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-green-50 rounded-xl p-4">
        <dt class="text-sm text-green-600 font-medium">Created</dt>
        <dd class="text-2xl font-bold text-green-700"><%= @result[:created_count] %></dd>
      </div>
      <div class="bg-slate-50 rounded-xl p-4">
        <dt class="text-sm text-slate-600 font-medium">Skipped</dt>
        <dd class="text-2xl font-bold text-slate-700"><%= @result[:skipped_count] %></dd>
      </div>
      <div class="bg-red-50 rounded-xl p-4">
        <dt class="text-sm text-red-600 font-medium">Errors</dt>
        <dd class="text-2xl font-bold text-red-700"><%= @result[:error_count] %></dd>
      </div>
    </dl>
  </div>

  <% if @result[:warnings]&.any? %>
    <div class="bg-white ring-1 ring-amber-200 rounded-xl overflow-hidden mb-6">
      <div class="px-6 py-4 border-b border-amber-100 bg-amber-50">
        <h2 class="text-lg font-semibold text-amber-700">Warnings — Auto-created Customers</h2>
        <p class="text-sm text-amber-600 mt-1">The following rows had no matching Customer or Prospect. A new Customer was auto-created for each.</p>
      </div>
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Row</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Detail</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @result[:warnings].each do |warning| %>
            <tr>
              <td class="px-6 py-3 text-sm text-slate-500"><%= warning[:row] %></td>
              <td class="px-6 py-3 text-sm text-amber-700"><%= warning[:messages].join(", ") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if @result[:errors].any? %>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden mb-6">
      <div class="px-6 py-4 border-b border-slate-100">
        <h2 class="text-lg font-semibold text-red-700">Error Details</h2>
      </div>
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Row</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Error</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @result[:errors].each do |error| %>
            <tr>
              <td class="px-6 py-3 text-sm text-slate-500"><%= error[:row] %></td>
              <td class="px-6 py-3 text-sm text-red-600"><%= error[:messages].join(", ") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div>
    <%= link_to "Import More", new_admin_import_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-slate-800 hover:bg-slate-700" %>
  </div>
</div>
