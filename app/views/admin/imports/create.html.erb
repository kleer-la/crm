<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Import Results: <%= @record_type.capitalize.pluralize %></h1>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <dl class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-green-50 rounded-lg p-4">
        <dt class="text-sm text-green-600 font-medium">Created</dt>
        <dd class="text-2xl font-bold text-green-700"><%= @result[:created_count] %></dd>
      </div>
      <div class="bg-gray-50 rounded-lg p-4">
        <dt class="text-sm text-gray-600 font-medium">Skipped</dt>
        <dd class="text-2xl font-bold text-gray-700"><%= @result[:skipped_count] %></dd>
      </div>
      <div class="bg-red-50 rounded-lg p-4">
        <dt class="text-sm text-red-600 font-medium">Errors</dt>
        <dd class="text-2xl font-bold text-red-700"><%= @result[:error_count] %></dd>
      </div>
    </dl>
  </div>

  <% if @result[:errors].any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden mb-6">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-red-700">Error Details</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Row</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Error</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @result[:errors].each do |error| %>
            <tr>
              <td class="px-6 py-3 text-sm text-gray-500"><%= error[:row] %></td>
              <td class="px-6 py-3 text-sm text-red-600"><%= error[:messages].join(", ") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div>
    <%= link_to "Import More", new_admin_import_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
  </div>
</div>
