<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Quick replies</h1>
    <%= link_to "New quick reply", new_admin_canned_response_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded mb-6">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
    <% if @canned_responses.any? %>
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Content</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Position</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @canned_responses.each do |cr| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">
                <%= cr.name %>
                <% if cr.system? %>
                  <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">system</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500 max-w-md truncate"><%= cr.content %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500"><%= cr.position %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                <%= link_to "Edit", edit_admin_canned_response_path(cr), class: "text-indigo-600 hover:text-indigo-800" %>
                <%= button_to "Delete", admin_canned_response_path(cr), method: :delete, class: "text-red-600 hover:text-red-800", data: { turbo_confirm: "Delete \"#{cr.name}\"?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-8 text-center text-slate-400">No quick replies yet.</p>
    <% end %>
  </div>

  <div class="mt-6 p-4 bg-slate-50 rounded-lg text-sm text-slate-600">
    <p class="font-medium mb-1">Auto-disconnect</p>
    <p>Conversations where the last message is outbound and older than <strong><%= ConversationAutoDisconnectJob::TIMEOUT_HOURS %> hours</strong> will automatically receive the disconnect message and be closed. Configure via <code>AUTO_DISCONNECT_HOURS</code> env var.</p>
  </div>
</div>
