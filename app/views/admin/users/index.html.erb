<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">User Management</h1>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded mb-6">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# Pending Users %>
  <% if @pending_users.any? %>
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3 text-yellow-800">
        Pending Approval (<%= @pending_users.count %>)
      </h2>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-yellow-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Registered</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @pending_users.each do |user| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= user.name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= user.email %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= user.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                  <%= turbo_frame_tag "user_#{user.id}_role" do %>
                    <%= button_to "Make Consultant", assign_role_admin_user_path(user, role: :consultant), method: :patch, class: "inline-block px-3 py-1 text-xs font-semibold text-blue-700 bg-blue-100 rounded hover:bg-blue-200 mr-2" %>
                    <%= button_to "Make Admin", assign_role_admin_user_path(user, role: :admin), method: :patch, class: "inline-block px-3 py-1 text-xs font-semibold text-purple-700 bg-purple-100 rounded hover:bg-purple-200" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <%# Active Users %>
  <section class="mb-8">
    <h2 class="text-lg font-semibold mb-3">
      Active Users (<%= @active_users.count %>)
    </h2>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @active_users.each do |user| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= user.name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= user.email %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= role_badge(user) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <% if user != current_user %>
                  <%= button_to "Deactivate", deactivate_admin_user_path(user), method: :patch, class: "inline-block px-3 py-1 text-xs font-semibold text-red-700 bg-red-100 rounded hover:bg-red-200", data: { turbo_confirm: "Deactivate #{user.name}?" } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# Deactivated Users %>
  <% if @deactivated_users.any? %>
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3 text-gray-500">
        Deactivated (<%= @deactivated_users.count %>)
      </h2>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @deactivated_users.each do |user| %>
              <tr class="bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-400">
                  <%= user.name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
                  <%= user.email %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <%= role_badge(user) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                  <%= button_to "Reactivate", reactivate_admin_user_path(user), method: :patch, class: "inline-block px-3 py-1 text-xs font-semibold text-green-700 bg-green-100 rounded hover:bg-green-200" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
