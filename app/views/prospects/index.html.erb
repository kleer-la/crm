<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Prospects</h1>
    <%= link_to "New Prospect", new_prospect_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700" %>
  </div>

  <%= render "shared/filter_bar", url: prospects_path do |f| %>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Company name...", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Status</label>
      <%= f.select :status, Prospect.statuses.keys.map { |s| [s.titleize, s] }, { include_blank: "All" }, value: params[:status], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Source</label>
      <%= f.select :source, Prospect.sources.keys.map { |s| [s.titleize, s] }, { include_blank: "All" }, value: params[:source], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Consultant</label>
      <%= f.select :consultant_id, User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { include_blank: "All" }, value: params[:consultant_id], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
  <% end %>

  <turbo-frame id="results">
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <%= render "shared/sortable_header", label: "Company", field: "company_name", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
            <%= render "shared/sortable_header", label: "Status", field: "status", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
            <%= render "shared/sortable_header", label: "Source", field: "source", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contact</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Consultant</th>
            <%= render "shared/sortable_header", label: "Est. Value", field: "estimated_value", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
            <%= render "shared/sortable_header", label: "Added", field: "date_added", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
            <%= render "shared/sortable_header", label: "Last Activity", field: "last_activity_date", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @prospects.each do |prospect| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to prospect.company_name, prospect, class: "text-blue-600 hover:text-blue-900 font-medium", data: { turbo_frame: "_top" } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(prospect.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= prospect.source&.titleize %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= prospect.primary_contact_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= prospect.responsible_consultant.display_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= currency(prospect.estimated_value) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= prospect.date_added&.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= prospect.last_activity_date&.strftime("%b %d, %Y") %>
              </td>
            </tr>
          <% end %>

          <% if @prospects.empty? %>
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-sm text-gray-500">
                No prospects found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </turbo-frame>
</div>
