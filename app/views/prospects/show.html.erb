<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= @prospect.company_name %></h1>
      <div class="mt-1 flex items-center gap-2">
        <%= status_badge(@prospect.status) %>
        <% if @prospect.converted? %>
          <span class="text-sm text-slate-500">
            Converted to <%= link_to @prospect.converted_customer.company_name, @prospect.converted_customer, class: "text-indigo-600 hover:text-indigo-900" %>
          </span>
        <% end %>
      </div>
    </div>

    <div class="mt-4 sm:mt-0 flex gap-2">
      <% unless @prospect.read_only? %>
        <%= link_to "Edit", edit_prospect_path(@prospect), class: "px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50" %>
        <% unless @prospect.disqualified? %>
          <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700"
                  onclick="document.getElementById('disqualify-modal').classList.remove('hidden')">
            Disqualify
          </button>
        <% end %>
        <% if @prospect.qualified? %>
          <%= button_to "Convert to Customer", convert_prospect_path(@prospect), method: :patch, class: "px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @prospect.read_only? %>
    <div class="mb-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <p class="text-sm text-yellow-800">This prospect has been converted to a customer and is now read-only.</p>
    </div>
  <% end %>

  <% if @prospect.disqualified? && @prospect.disqualification_reason.present? %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800">Disqualification Reason:</p>
      <p class="text-sm text-red-700 mt-1"><%= @prospect.disqualification_reason %></p>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Details column %>
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Details</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-sm font-medium text-slate-500">Industry</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.industry.presence || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Country</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.country.presence || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Source</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.source&.titleize || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Estimated Value</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= currency(@prospect.estimated_value) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Date Added</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.date_added&.strftime("%b %d, %Y") %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Last Activity</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.last_activity_date&.strftime("%b %d, %Y") %></dd>
          </div>
        </dl>
      </div>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Contact Information</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-sm font-medium text-slate-500">Name</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.primary_contact_name %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Email</dt>
            <dd class="mt-1 text-sm text-slate-900">
              <%= mail_to @prospect.primary_contact_email, @prospect.primary_contact_email, class: "text-indigo-600 hover:text-indigo-900" %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Phone</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.primary_contact_phone.presence || "—" %></dd>
          </div>
        </dl>
      </div>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Consultants</h2>
        <dl class="space-y-3">
          <div>
            <dt class="text-sm font-medium text-slate-500">Responsible</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @prospect.responsible_consultant.display_name %></dd>
          </div>
          <% if @prospect.collaborating_consultants.any? %>
            <div>
              <dt class="text-sm font-medium text-slate-500">Collaborators</dt>
              <dd class="mt-1 text-sm text-slate-900">
                <%= @prospect.collaborating_consultants.map(&:display_name).join(", ") %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>

      <% unless @prospect.read_only? %>
        <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-slate-900">Tasks</h2>
            <%= link_to "New Task", new_task_path(linkable_type: "Prospect", linkable_id: @prospect.id), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
          </div>
          <% tasks = @prospect.tasks.where.not(status: [:done, :cancelled]).order(due_date: :asc) %>
          <% if tasks.any? %>
            <div class="space-y-2">
              <% tasks.each do |task| %>
                <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2">
                  <div>
                    <%= link_to task.title, task, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                    <span class="text-slate-400 ml-1">due <%= task.due_date.strftime("%b %d") %></span>
                    <% if task.due_date < Date.current %>
                      <span class="text-red-500 text-xs ml-1">(overdue)</span>
                    <% end %>
                  </div>
                  <%= status_badge(task.status) %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-slate-500">No active tasks.</p>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Sidebar column %>
    <div class="space-y-6">
      <% unless @prospect.read_only? %>
        <%= render "shared/touchpoint_form", record: @prospect %>
      <% end %>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
        <h3 class="text-sm font-semibold text-slate-900 mb-3">Activity</h3>
        <%= render "shared/activity_timeline", activity_logs: @prospect.activity_logs.includes(:user).order(created_at: :desc) %>
      </div>
    </div>
  </div>

  <%# Disqualify Modal %>
  <% unless @prospect.read_only? || @prospect.disqualified? %>
    <div id="disqualify-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
      <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-slate-500/75" onclick="document.getElementById('disqualify-modal').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Disqualify Prospect</h3>
          <%= form_with url: disqualify_prospect_path(@prospect), method: :patch, class: "space-y-4" do |f| %>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Reason</label>
              <%= f.text_area "prospect[disqualification_reason]", rows: 3, required: true,
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
                placeholder: "Why is this prospect being disqualified?" %>
            </div>
            <div class="flex justify-end gap-3">
              <button type="button" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50"
                      onclick="document.getElementById('disqualify-modal').classList.add('hidden')">
                Cancel
              </button>
              <%= f.submit "Disqualify", class: "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
