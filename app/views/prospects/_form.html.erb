<%= form_with(model: prospect, class: "space-y-0") do |f| %>
  <%= render "shared/error_summary", record: prospect %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
    <%= render "shared/form_field", form: f, field: :company_name, label: "Company name", required: true %>
    <%= render "shared/form_field", form: f, field: :industry, label: "Industry" %>
    <%= render "shared/form_field", form: f, field: :country, label: "Country" %>
    <%= render "shared/form_field", form: f, field: :primary_contact_name, label: "Primary contact name", required: true %>
    <%= render "shared/form_field", form: f, field: :primary_contact_email, label: "Primary contact email", type: :email_field, required: true %>
    <%= render "shared/form_field", form: f, field: :primary_contact_phone, label: "Primary contact phone" %>
    <%= render "shared/form_field", form: f, field: :source, label: "Source", type: :select, options: { choices: Prospect.sources.keys.map { |s| [s.humanize, s] }, include_blank: "Select source..." } %>
    <%= render "shared/form_field", form: f, field: :estimated_value, label: "Estimated value", type: :number_field %>
    <%= render "shared/form_field", form: f, field: :date_added, label: "Date added", type: :date_field, required: true %>
    <% if prospect.persisted? && !prospect.converted? %>
      <%= render "shared/form_field", form: f, field: :status, label: "Status", type: :select, options: { choices: Prospect.statuses.keys.reject { |s| s == "converted" }.map { |s| [s.humanize, s] } } %>
    <% end %>
  </div>

  <%= render "shared/consultant_select", form: f, field: :responsible_consultant_id, label: "Responsible consultant", required: true %>
  <%= render "shared/consultant_multi_select", form: f, field: :collaborating_consultant_ids, label: "Collaborating consultants" %>

  <%= render "shared/form_actions", form: f, cancel_path: prospect.persisted? ? prospect_path(prospect) : prospects_path %>
<% end %>
