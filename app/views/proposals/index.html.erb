<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Proposals</h1>
    <%= link_to "New Proposal", new_proposal_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700" %>
  </div>

  <%= render "shared/filter_bar", url: proposals_path do |f| %>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Title...", class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Status</label>
      <%= f.select :status, Proposal.statuses.keys.map { |s| [s.titleize, s] }, { include_blank: "All" }, value: params[:status], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Linked To</label>
      <%= f.select :linkable_type, [["Prospect", "Prospect"], ["Customer", "Customer"]], { include_blank: "All" }, value: params[:linkable_type], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Consultant</label>
      <%= f.select :consultant_id, User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { include_blank: "All" }, value: params[:consultant_id], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
  <% end %>

  <turbo-frame id="results">
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <%= render "shared/sortable_header", label: "Status", field: "status", current_sort: params[:sort], current_dir: params[:dir], url: proposals_path %>
            <%= render "shared/sortable_header", label: "Asked", field: "date_asked", current_sort: params[:sort], current_dir: params[:dir], url: proposals_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Linked To</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Consultant</th>
            <%= render "shared/sortable_header", label: "Title", field: "title", current_sort: params[:sort], current_dir: params[:dir], url: proposals_path %>
            <%= render "shared/sortable_header", label: "Est. Value", field: "estimated_value", current_sort: params[:sort], current_dir: params[:dir], url: proposals_path %>
            <%= render "shared/sortable_header", label: "Expected Close", field: "expected_close_date", current_sort: params[:sort], current_dir: params[:dir], url: proposals_path %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          <% @proposals.each do |proposal| %>
            <tr class="hover:bg-indigo-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(proposal.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= proposal.date_asked&.strftime("%b %d, %Y") || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= link_to proposal.linkable.company_name, proposal.linkable, class: "text-indigo-600 hover:text-indigo-900", data: { turbo_frame: "_top" } %>
                <span class="text-xs text-slate-400">(<%= proposal.linkable_type %>)</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= proposal.responsible_consultant.display_name %>
              </td>
              <td class="px-6 py-4 max-w-xs">
                <%= link_to truncate(proposal.title, length: 40), proposal, class: "text-indigo-600 hover:text-indigo-900 font-medium", data: { turbo_frame: "_top" } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                <%= currency(proposal.estimated_value) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= proposal.expected_close_date&.strftime("%b %d, %Y") || "—" %>
              </td>
            </tr>
          <% end %>

          <% if @proposals.empty? %>
            <tr>
              <td colspan="8" class="px-6 py-16 text-center">
                <svg class="mx-auto h-10 w-10 text-slate-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <p class="text-sm font-medium text-slate-900 mb-1">No proposals found</p>
                <p class="text-xs text-slate-500 mb-4">Try adjusting your filters or create a new proposal</p>
                <%= link_to "New Proposal", new_proposal_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </turbo-frame>
</div>
