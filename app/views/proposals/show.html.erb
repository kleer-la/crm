<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= @proposal.title %></h1>
      <div class="mt-1 flex items-center gap-2">
        <%= status_badge(@proposal.status) %>
        <span class="text-sm text-slate-500">
          linked to
          <%= link_to @proposal.linkable.company_name, polymorphic_path(@proposal.linkable), class: "text-indigo-600 hover:text-indigo-900" %>
          (<%= @proposal.linkable_type %>)
        </span>
      </div>
    </div>

    <div class="mt-4 sm:mt-0 flex gap-2">
      <% unless @proposal.won? || @proposal.lost? || @proposal.cancelled? %>
        <%= link_to "Edit", edit_proposal_path(@proposal), class: "px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50" %>
      <% end %>

      <% unless @proposal.won? || @proposal.lost? || @proposal.cancelled? %>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700"
                onclick="document.getElementById('won-modal').classList.remove('hidden')">
          Mark as Won
        </button>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700"
                onclick="document.getElementById('lost-modal').classList.remove('hidden')">
          Mark as Lost
        </button>
      <% end %>

      <%= button_to "Duplicate", duplicate_proposal_path(@proposal), method: :post, class: "px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50" %>
    </div>
  </div>

  <% if @proposal.won? && @proposal.linkable.is_a?(Prospect) && !@proposal.linkable.converted? %>
    <div class="mb-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4 flex items-center justify-between">
      <p class="text-sm text-yellow-800">
        This proposal is Won but the linked Prospect has not been converted to a Customer.
      </p>
      <%= button_to "Convert Prospect", convert_prospect_path(@proposal.linkable), method: :patch, class: "px-3 py-1 text-sm font-medium text-white bg-yellow-600 rounded-lg hover:bg-yellow-700" %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Details column %>
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Details</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-sm font-medium text-slate-500">Estimated value</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= currency(@proposal.estimated_value) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Date asked</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @proposal.date_asked&.strftime("%b %d, %Y") || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Date sent</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @proposal.date_sent&.strftime("%b %d, %Y") || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Expected close date</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @proposal.expected_close_date&.strftime("%b %d, %Y") || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Actual close date</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @proposal.actual_close_date&.strftime("%b %d, %Y") || "—" %></dd>
          </div>
          <% if @proposal.win_loss_reason.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-slate-500">Win/Loss Reason</dt>
              <dd class="mt-1 text-sm text-slate-900"><%= @proposal.win_loss_reason %></dd>
            </div>
          <% end %>
          <% if @proposal.notes.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-slate-500">Notes</dt>
              <dd class="mt-1 text-sm text-slate-900 whitespace-pre-wrap"><%= @proposal.notes %></dd>
            </div>
          <% end %>
          <% if @proposal.description.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-slate-500">Description</dt>
              <dd class="mt-1 text-sm text-slate-900 whitespace-pre-wrap"><%= @proposal.description %></dd>
            </div>
          <% end %>
        </dl>
      </div>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Consultants</h2>
        <dl class="space-y-3">
          <div>
            <dt class="text-sm font-medium text-slate-500">Responsible</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @proposal.responsible_consultant.display_name %></dd>
          </div>
          <% if @proposal.collaborating_consultants.any? %>
            <div>
              <dt class="text-sm font-medium text-slate-500">Collaborators</dt>
              <dd class="mt-1 text-sm text-slate-900">
                <%= @proposal.collaborating_consultants.map(&:display_name).join(", ") %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>

      <%# Document Link Management %>
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Document</h2>
        <% if @proposal.current_document_url.present? %>
          <div class="flex items-center justify-between mb-4">
            <a href="<%= @proposal.current_document_url %>" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-900 text-sm truncate">
              <%= @proposal.current_document_url %>
            </a>
            <button type="button" class="ml-4 text-sm text-slate-500 hover:text-slate-700"
                    onclick="document.getElementById('archive-modal').classList.remove('hidden')">
              Replace & archive
            </button>
          </div>
        <% else %>
          <p class="text-sm text-slate-500 mb-4">No document link set.</p>
        <% end %>

        <%# Document Version History %>
        <% if @document_versions.any? %>
          <h3 class="text-sm font-semibold text-slate-700 mt-4 mb-2">Version History</h3>
          <div class="space-y-2">
            <% @document_versions.each do |version| %>
              <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2">
                <div>
                  <span class="font-medium text-slate-900"><%= version.label %></span>
                  <span class="text-slate-500 ml-2"><%= version.archived_at.strftime("%b %d, %Y") %></span>
                  <span class="text-slate-400 ml-1">by <%= version.archived_by.display_name %></span>
                </div>
                <a href="<%= version.url %>" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-900 truncate ml-4" style="max-width: 200px;">
                  <%= version.url %>
                </a>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-slate-900">Tasks</h2>
          <%= link_to "New task", new_task_path(linkable_type: "Proposal", linkable_id: @proposal.id), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        </div>
        <% tasks = @proposal.tasks.where.not(status: [:done, :cancelled]).order(due_date: :asc) %>
        <% if tasks.any? %>
          <div class="space-y-2">
            <% tasks.each do |task| %>
              <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2">
                <div>
                  <%= link_to task.title, task, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
                  <span class="text-slate-400 ml-1">due <%= task.due_date.strftime("%b %d") %></span>
                  <% if task.due_date < Date.current && (task.open? || task.in_progress?) %>
                    <span class="text-red-500 text-xs ml-1">(overdue)</span>
                  <% end %>
                </div>
                <%= status_badge(task.status) %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">No active tasks.</p>
        <% end %>
      </div>
    </div>

    <%# Sidebar column %>
    <div class="space-y-6">
      <%= render "shared/touchpoint_form", record: @proposal %>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
        <h3 class="text-sm font-semibold text-slate-900 mb-3">Activity</h3>
        <%= render "shared/activity_timeline", activity_logs: @proposal.activity_logs.includes(:user).order(occurred_at: :desc) %>
      </div>
    </div>
  </div>

  <%# Mark as Won Modal %>
  <% unless @proposal.won? || @proposal.lost? || @proposal.cancelled? %>
    <div id="won-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
      <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-slate-500/75" onclick="document.getElementById('won-modal').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Mark Proposal as Won</h3>
          <%= form_with url: mark_won_proposal_path(@proposal), method: :patch, class: "space-y-4" do |f| %>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Reason</label>
              <%= f.text_area "proposal[win_loss_reason]", rows: 3, required: true,
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
                placeholder: "Why was this proposal won?" %>
            </div>
            <div class="flex justify-end gap-3">
              <button type="button" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50"
                      onclick="document.getElementById('won-modal').classList.add('hidden')">
                Cancel
              </button>
              <%= f.submit "Mark as Won", class: "px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Mark as Lost Modal %>
    <div id="lost-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
      <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-slate-500/75" onclick="document.getElementById('lost-modal').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Mark Proposal as Lost</h3>
          <%= form_with url: mark_lost_proposal_path(@proposal), method: :patch, class: "space-y-4" do |f| %>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Reason</label>
              <%= f.text_area "proposal[win_loss_reason]", rows: 3, required: true,
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
                placeholder: "Why was this proposal lost?" %>
            </div>
            <div class="flex justify-end gap-3">
              <button type="button" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50"
                      onclick="document.getElementById('lost-modal').classList.add('hidden')">
                Cancel
              </button>
              <%= f.submit "Mark as Lost", class: "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Archive Document Modal %>
  <% if @proposal.current_document_url.present? %>
    <div id="archive-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
      <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-slate-500/75" onclick="document.getElementById('archive-modal').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Replace Document Link</h3>
          <p class="text-sm text-slate-500 mb-4">The current link will be archived to version history.</p>
          <%= form_with url: archive_document_proposal_path(@proposal), method: :post, class: "space-y-4" do |f| %>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Archive label</label>
              <%= f.text_field :label, placeholder: "e.g., Version 1.0",
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">New document URL</label>
              <%= f.url_field :new_url, required: true, placeholder: "https://...",
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
            </div>
            <div class="flex justify-end gap-3">
              <button type="button" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50"
                      onclick="document.getElementById('archive-modal').classList.add('hidden')">
                Cancel
              </button>
              <%= f.submit "Archive & Replace", class: "px-4 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
