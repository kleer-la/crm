<div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-sm font-semibold text-slate-900">Tasks</h3>

    <%= link_to "New task", new_task_path(linkable_type: linkable.class.name, linkable_id: linkable.id),
        class: "text-sm text-indigo-600 hover:text-indigo-900",
        data: { turbo_frame: "modal" } %>
  </div>
  <% tasks = linkable.tasks.where.not(status: [:done, :cancelled]).order(due_date: :asc) %>
  <% if tasks.any? %>
    <div class="space-y-2">
      <% tasks.each do |task| %>
        <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2">
          <div>
            <%= link_to task.title, edit_task_path(task), class: "text-indigo-600 hover:text-indigo-900 font-medium", data: { turbo_frame: "modal" } %>
            <span class="text-slate-400 ml-1">due <%= task.due_date.strftime("%b %d") %></span>
            <% if task.due_date < Date.current && (task.open? || task.in_progress?) %>
              <span class="text-red-500 text-xs ml-1">(overdue)</span>
            <% end %>
          </div>
          <%= status_badge(task.status) %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500">No active tasks.</p>
  <% end %>
</div>
