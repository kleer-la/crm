<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= @task.title %></h1>
      <div class="mt-1 flex items-center gap-2">
        <%= status_badge(@task.status) %>
        <% priority_colors = { "low" => "bg-slate-100 text-slate-600", "medium" => "bg-amber-100 text-amber-700", "high" => "bg-red-100 text-red-700" } %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_colors[@task.priority] %>">
          <%= @task.priority.titleize %>
        </span>
        <% if @task.due_date < Date.current && (@task.open? || @task.in_progress?) %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
            Overdue
          </span>
        <% end %>
      </div>
    </div>

    <div class="mt-4 sm:mt-0 flex gap-2">
      <% if @task.open? || @task.in_progress? %>
        <%= link_to "Edit", edit_task_path(@task), class: "px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50" %>
        <%= button_to "Mark as Done", mark_done_task_path(@task), method: :patch, class: "px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700" %>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700"
                onclick="document.getElementById('cancel-modal').classList.remove('hidden')">
          Cancel Task
        </button>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Details column %>
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Details</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-sm font-medium text-slate-500">Linked To</dt>
            <dd class="mt-1 text-sm text-slate-900">
              <% linkable_name = @task.linkable.respond_to?(:company_name) ? @task.linkable.company_name : @task.linkable.title %>
              <%= link_to linkable_name, polymorphic_path(@task.linkable), class: "text-indigo-600 hover:text-indigo-900" %>
              <span class="text-xs text-slate-400">(<%= @task.linkable_type %>)</span>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Assigned To</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @task.assigned_to.display_name %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Due Date</dt>
            <dd class="mt-1 text-sm <%= (@task.due_date < Date.current && (@task.open? || @task.in_progress?)) ? 'text-red-600 font-semibold' : 'text-slate-900' %>">
              <%= @task.due_date.strftime("%b %d, %Y") %>
            </dd>
          </div>
          <% if @task.completed_at.present? %>
            <div>
              <dt class="text-sm font-medium text-slate-500">Completed At</dt>
              <dd class="mt-1 text-sm text-slate-900"><%= @task.completed_at.strftime("%b %d, %Y %H:%M") %></dd>
            </div>
          <% end %>
          <% if @task.cancellation_reason.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-slate-500">Cancellation Reason</dt>
              <dd class="mt-1 text-sm text-slate-900"><%= @task.cancellation_reason %></dd>
            </div>
          <% end %>
          <% if @task.notes.present? %>
            <div class="sm:col-span-2">
              <dt class="text-sm font-medium text-slate-500">Notes</dt>
              <dd class="mt-1 text-sm text-slate-900 whitespace-pre-wrap"><%= @task.notes %></dd>
            </div>
          <% end %>
        </dl>
      </div>

      <% if @task.open? || @task.in_progress? %>
        <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-slate-900 mb-4">Reassign</h2>
          <%= form_with url: reassign_task_path(@task), method: :patch, class: "flex items-end gap-4" do |f| %>
            <div class="flex-1">
              <label class="block text-sm font-medium text-slate-700 mb-1">Assigned To</label>
              <%= f.select "task[assigned_to_id]", User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { selected: @task.assigned_to_id },
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
            </div>
            <%= f.submit "Reassign", class: "px-4 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700 cursor-pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Sidebar column %>
    <div class="space-y-6">
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
        <h3 class="text-sm font-semibold text-slate-900 mb-3">Activity</h3>
        <%= render "shared/activity_timeline", activity_logs: @task.activity_logs.includes(:user).order(created_at: :desc) %>
      </div>
    </div>
  </div>

  <%# Cancel Modal %>
  <% if @task.open? || @task.in_progress? %>
    <div id="cancel-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
      <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-slate-500/75" onclick="document.getElementById('cancel-modal').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Cancel Task</h3>
          <%= form_with url: cancel_task_path(@task), method: :patch, class: "space-y-4" do |f| %>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Reason</label>
              <%= f.text_area "task[cancellation_reason]", rows: 3, required: true,
                class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
                placeholder: "Why is this task being cancelled?" %>
            </div>
            <div class="flex justify-end gap-3">
              <button type="button" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50"
                      onclick="document.getElementById('cancel-modal').classList.add('hidden')">
                Go Back
              </button>
              <%= f.submit "Cancel Task", class: "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
