<%= form_with(model: task, class: "space-y-0") do |f| %>
  <%= render "shared/error_summary", record: task %>

  <%= render "shared/form_field", form: f, field: :title, label: "Title", required: true %>

  <% if task.linkable_type.present? && task.linkable_id.present? %>
    <%= f.hidden_field :linkable_type %>
    <%= f.hidden_field :linkable_id %>
  <% else %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700 mb-1">Linked to <span class="text-xs text-slate-400 font-normal">optional</span></label>
      <div class="flex gap-2" data-controller="linkable-type" data-linkable-type-url-value="<%= new_task_path %>">
        <%= f.select :linkable_type, [["Prospect", "Prospect"], ["Customer", "Customer"], ["Proposal", "Proposal"]],
          { include_blank: "Select type..." },
          class: "block w-1/3 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
          data: { action: "change->linkable-type#change" } %>
        <turbo-frame id="linkable_id_select" class="contents">
          <% if task.linkable_type == "Prospect" %>
            <%= f.select :linkable_id, Prospect.where.not(status: :converted).order(:company_name).map { |p| [p.company_name, p.id] },
              { include_blank: "Select prospect..." },
              class: "block w-2/3 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
          <% elsif task.linkable_type == "Customer" %>
            <%= f.select :linkable_id, Customer.order(:company_name).map { |c| [c.company_name, c.id] },
              { include_blank: "Select customer..." },
              class: "block w-2/3 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
          <% elsif task.linkable_type == "Proposal" %>
            <%= f.select :linkable_id, Proposal.includes(:linkable).order(:title).map { |p| ["#{p.title} (#{p.linkable.respond_to?(:company_name) ? p.linkable.company_name : p.linkable_type})", p.id] },
              { include_blank: "Select proposal..." },
              class: "block w-2/3 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
          <% else %>
            <%= f.select :linkable_id, [],
              { include_blank: "Select type first..." },
              disabled: true,
              class: "block w-2/3 rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-sm text-slate-400 shadow-sm" %>
          <% end %>
        </turbo-frame>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-x-6">
    <%= render "shared/form_field", form: f, field: :due_date, label: "Due date", type: :date_field, required: true %>

    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700 mb-1">Priority</label>
      <%= f.select :priority, Task.priorities.keys.map { |p| [p.humanize, p] },
        {},
        class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
  </div>

  <%= render "shared/consultant_select", form: f, field: :assigned_to_id, label: "Assigned to", required: true %>

  <div class="mb-4">
    <label class="block text-sm font-medium text-slate-700 mb-1">Notes <span class="text-xs text-slate-400 font-normal">optional</span></label>
    <%= f.text_area :notes, rows: 4, class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
  </div>

  <% if task.persisted? %>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-700 mb-1">Status</label>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.humanize, s] },
        {},
        class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <% if task.cancelled? %>
      <%= render "shared/form_field", form: f, field: :cancellation_reason, label: "Cancellation reason", required: true %>
    <% end %>
  <% end %>

  <%= render "shared/form_actions", form: f, cancel_path: task.persisted? ? task_path(task) : tasks_path %>
<% end %>
