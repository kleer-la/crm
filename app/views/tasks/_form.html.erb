<%= form_with(model: task, class: "space-y-0") do |f| %>
  <%= render "shared/error_summary", record: task %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
    <%= render "shared/form_field", form: f, field: :title, label: "Title", required: true %>

    <div class="py-3">
      <label class="block text-sm font-medium text-gray-700 mb-1">Linked To <span class="text-red-500">*</span></label>
      <div class="flex gap-2">
        <%= f.select :linkable_type, [["Prospect", "Prospect"], ["Customer", "Customer"], ["Proposal", "Proposal"]],
          { include_blank: "Select type..." },
          class: "block w-1/3 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        <% if task.linkable_type == "Prospect" %>
          <%= f.select :linkable_id, Prospect.where.not(status: :converted).order(:company_name).map { |p| [p.company_name, p.id] },
            { include_blank: "Select prospect..." },
            class: "block w-2/3 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        <% elsif task.linkable_type == "Customer" %>
          <%= f.select :linkable_id, Customer.order(:company_name).map { |c| [c.company_name, c.id] },
            { include_blank: "Select customer..." },
            class: "block w-2/3 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        <% elsif task.linkable_type == "Proposal" %>
          <%= f.select :linkable_id, Proposal.includes(:linkable).order(:title).map { |p| ["#{p.title} (#{p.linkable.respond_to?(:company_name) ? p.linkable.company_name : p.linkable_type})", p.id] },
            { include_blank: "Select proposal..." },
            class: "block w-2/3 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        <% else %>
          <%= f.select :linkable_id, [], { include_blank: "Select type first..." },
            disabled: true,
            class: "block w-2/3 rounded-md border-gray-300 shadow-sm sm:text-sm bg-gray-50" %>
        <% end %>
      </div>
    </div>

    <%= render "shared/form_field", form: f, field: :due_date, label: "Due Date", type: :date_field, required: true %>

    <div class="py-3">
      <label class="block text-sm font-medium text-gray-700 mb-1">Priority <span class="text-red-500">*</span></label>
      <%= f.select :priority, Task.priorities.keys.map { |p| [p.titleize, p] },
        {},
        class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
  </div>

  <%= render "shared/consultant_select", form: f, field: :assigned_to_id, label: "Assigned To", required: true %>

  <div class="py-3">
    <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
    <%= f.text_area :notes, rows: 4, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <% if task.persisted? %>
    <div class="py-3">
      <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.titleize, s] },
        {},
        class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <% if task.cancelled? %>
      <%= render "shared/form_field", form: f, field: :cancellation_reason, label: "Cancellation Reason", required: true %>
    <% end %>
  <% end %>

  <%= render "shared/form_actions", form: f, cancel_path: task.persisted? ? task_path(task) : tasks_path %>
<% end %>
