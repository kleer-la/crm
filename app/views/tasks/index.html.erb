<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Tasks</h1>
    <%= link_to "New task", new_task_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700" %>
  </div>

  <%= render "shared/filter_bar", url: tasks_path do |f| %>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Title...", class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Status</label>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "All" }, value: params[:status], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Priority</label>
      <%= f.select :priority, Task.priorities.keys.map { |p| [p.humanize, p] }, { include_blank: "All" }, value: params[:priority], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Linked to</label>
      <%= f.select :linkable_type, [["Prospect", "Prospect"], ["Customer", "Customer"], ["Proposal", "Proposal"]], { include_blank: "All" }, value: params[:linkable_type], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Assigned to</label>
      <%= f.select :consultant_id, User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { include_blank: "All" }, value: params[:consultant_id], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div class="flex items-end">
      <label class="flex items-center gap-2 text-sm text-slate-700">
        <%= f.check_box :overdue, { checked: params[:overdue] == "1" }, "1", "0" %>
        Overdue only
      </label>
    </div>
  <% end %>

  <turbo-frame id="results">
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <%= render "shared/sortable_header", label: "Title", field: "title", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Linked to</th>
            <%= render "shared/sortable_header", label: "Status", field: "status", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
            <%= render "shared/sortable_header", label: "Priority", field: "priority", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Assigned to</th>
            <%= render "shared/sortable_header", label: "Due date", field: "due_date", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          <% @tasks.each do |task| %>
            <% overdue = task.due_date < Date.current && (task.open? || task.in_progress?) %>
            <tr class="<%= overdue ? 'bg-red-50 hover:bg-red-100' : 'hover:bg-indigo-50' %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to task.title, task, class: "text-indigo-600 hover:text-indigo-900 font-medium", data: { turbo_frame: "_top" } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <% linkable_name = task.linkable.respond_to?(:company_name) ? task.linkable.company_name : task.linkable.title %>
                <%= link_to linkable_name, task.linkable, class: "text-indigo-600 hover:text-indigo-900", data: { turbo_frame: "_top" } %>
                <span class="text-xs text-slate-400">(<%= task.linkable_type %>)</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(task.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% priority_colors = { "low" => "bg-slate-100 text-slate-600", "medium" => "bg-amber-100 text-amber-700", "high" => "bg-red-100 text-red-700" } %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_colors[task.priority] %>">
                  <%= task.priority.humanize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= task.assigned_to.display_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm <%= overdue ? 'text-red-600 font-semibold' : 'text-slate-500' %>">
                <%= task.due_date.strftime("%b %d, %Y") %>
                <% if overdue %>
                  <span class="text-xs text-red-500 ml-1">(overdue)</span>
                <% end %>
              </td>
            </tr>
          <% end %>

          <% if @tasks.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-16 text-center">
                <svg class="mx-auto h-10 w-10 text-slate-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                <p class="text-sm font-medium text-slate-900 mb-1">No tasks found</p>
                <p class="text-xs text-slate-500">Try adjusting your filters or create a new task using the button above</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </turbo-frame>
</div>
