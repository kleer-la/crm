<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Tasks</h1>
    <%= link_to "New Task", new_task_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700" %>
  </div>

  <%= render "shared/filter_bar", url: tasks_path do |f| %>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Title...", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Status</label>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.titleize, s] }, { include_blank: "All" }, value: params[:status], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Priority</label>
      <%= f.select :priority, Task.priorities.keys.map { |p| [p.titleize, p] }, { include_blank: "All" }, value: params[:priority], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Linked To</label>
      <%= f.select :linkable_type, [["Prospect", "Prospect"], ["Customer", "Customer"], ["Proposal", "Proposal"]], { include_blank: "All" }, value: params[:linkable_type], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">Assigned To</label>
      <%= f.select :consultant_id, User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { include_blank: "All" }, value: params[:consultant_id], class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
    <div class="flex items-end">
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= f.check_box :overdue, { checked: params[:overdue] == "1" }, "1", "0" %>
        Overdue only
      </label>
    </div>
  <% end %>

  <turbo-frame id="results">
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <%= render "shared/sortable_header", label: "Title", field: "title", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Linked To</th>
            <%= render "shared/sortable_header", label: "Status", field: "status", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
            <%= render "shared/sortable_header", label: "Priority", field: "priority", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned To</th>
            <%= render "shared/sortable_header", label: "Due Date", field: "due_date", current_sort: params[:sort], current_dir: params[:dir], url: tasks_path %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @tasks.each do |task| %>
            <% overdue = task.due_date < Date.current && (task.open? || task.in_progress?) %>
            <tr class="<%= overdue ? 'bg-red-50 hover:bg-red-100' : 'hover:bg-gray-50' %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to task.title, task, class: "text-blue-600 hover:text-blue-900 font-medium" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% linkable_name = task.linkable.respond_to?(:company_name) ? task.linkable.company_name : task.linkable.title %>
                <%= link_to linkable_name, task.linkable, class: "text-blue-600 hover:text-blue-900" %>
                <span class="text-xs text-gray-400">(<%= task.linkable_type %>)</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(task.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% priority_colors = { "low" => "bg-gray-100 text-gray-800", "medium" => "bg-yellow-100 text-yellow-800", "high" => "bg-red-100 text-red-800" } %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= priority_colors[task.priority] %>">
                  <%= task.priority.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= task.assigned_to.display_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm <%= overdue ? 'text-red-600 font-semibold' : 'text-gray-500' %>">
                <%= task.due_date.strftime("%b %d, %Y") %>
                <% if overdue %>
                  <span class="text-xs text-red-500 ml-1">(overdue)</span>
                <% end %>
              </td>
            </tr>
          <% end %>

          <% if @tasks.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-sm text-gray-500">
                No tasks found.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </turbo-frame>
</div>
