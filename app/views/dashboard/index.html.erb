<div class="px-4 sm:px-6 lg:px-8 py-8" data-controller="dashboard-tabs">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Dashboard</h1>
  </div>

  <%# Always-visible team KPI strip %>
  <%= render "kpi_strip" %>

  <%# Tab navigation %>
  <div class="border-b border-slate-200 mb-6">
    <nav class="-mb-px flex space-x-8" aria-label="Dashboard tabs">
      <button type="button"
              data-dashboard-tabs-target="teamTab"
              data-action="click->dashboard-tabs#showTeam"
              aria-selected="true"
              class="py-3 px-1 text-sm font-medium border-b-2 border-indigo-600 text-indigo-600 aria-[selected=false]:border-transparent aria-[selected=false]:text-slate-500 aria-[selected=false]:hover:text-slate-700 aria-[selected=false]:hover:border-slate-300 transition-colors whitespace-nowrap">
        Team
      </button>
      <button type="button"
              data-dashboard-tabs-target="mineTab"
              data-action="click->dashboard-tabs#showMine"
              aria-selected="false"
              class="py-3 px-1 text-sm font-medium border-b-2 border-indigo-600 text-indigo-600 aria-[selected=false]:border-transparent aria-[selected=false]:text-slate-500 aria-[selected=false]:hover:text-slate-700 aria-[selected=false]:hover:border-slate-300 transition-colors whitespace-nowrap">
        Mine
      </button>
    </nav>
  </div>

  <%# Team tab (eager-loaded) %>
  <div data-dashboard-tabs-target="teamPanel">
    <%= turbo_frame_tag "dashboard-team", src: dashboard_team_panel_path %>
  </div>

  <%# Mine tab (lazy-loaded — request fires only when panel becomes visible) %>
  <div data-dashboard-tabs-target="minePanel" hidden>
    <%= turbo_frame_tag "dashboard-mine", src: dashboard_mine_panel_path, loading: :lazy %>
  </div>
</div>
