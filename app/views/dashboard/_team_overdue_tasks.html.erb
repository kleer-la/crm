<% if team_overdue_tasks.any? %>
  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
    <h2 class="text-sm font-semibold text-slate-900 mb-3">Overdue tasks</h2>
    <div class="space-y-2">
      <% team_overdue_tasks.each do |task| %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-3">
          <p class="text-sm text-red-800">
            <%= link_to task.title, task, class: "font-semibold text-red-900 underline hover:text-red-700" %>
            — due <%= task.due_date.strftime("%b %d") %>
            <span class="text-xs text-red-600 ml-1">(<%= task.assigned_to.display_name %>)</span>
          </p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
