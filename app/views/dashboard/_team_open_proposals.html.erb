<div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-slate-900">Open proposals</h2>
    <%= link_to "View all", proposals_path, class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>
  <% if team_open_proposals.any? %>
    <div class="space-y-2">
      <% team_open_proposals.each do |proposal| %>
        <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2">
          <div class="min-w-0 flex-1">
            <%= link_to proposal.title, proposal, class: "text-indigo-600 hover:text-indigo-900 font-medium truncate block" %>
            <span class="text-slate-400">
              <%= proposal.linkable.company_name %>
              · <%= proposal.responsible_consultant.display_name %>
            </span>
          </div>
          <span class="text-sm text-slate-500 ml-4 flex-shrink-0"><%= currency(proposal.estimated_value) %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500">No open proposals.</p>
  <% end %>
</div>
