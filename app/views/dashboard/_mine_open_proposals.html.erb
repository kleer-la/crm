<div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-slate-900">My open proposals</h2>
    <%= link_to "View all", proposals_path(consultant_id: current_user.id), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>
  <% if my_proposals.any? %>
    <% my_proposals.group_by(&:status).each do |status, proposals| %>
      <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-3 mb-2"><%= status.humanize %> (<%= proposals.size %>)</h3>
      <div class="space-y-2">
        <% proposals.each do |proposal| %>
          <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2">
            <div>
              <%= link_to proposal.title, proposal, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              <span class="text-slate-400 ml-1">— <%= proposal.linkable.company_name %></span>
            </div>
            <span class="text-sm text-slate-500"><%= currency(proposal.estimated_value) %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-sm text-slate-500">No open proposals.</p>
  <% end %>
</div>
