<%= turbo_frame_tag "dashboard-mine" do %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Main column — my alerts + worklists %>
    <div class="lg:col-span-2 space-y-6">
      <%= render "mine_pending_conversions", my_pending_conversions: @my_pending_conversions %>
      <%= render "mine_stale_proposals", my_stale_proposals: @my_stale_proposals %>
      <%= render "mine_open_tasks", my_tasks: @my_tasks %>
      <%= render "mine_open_proposals", my_proposals: @my_proposals %>
      <%= render "mine_active_prospects", my_prospects: @my_prospects %>
    </div>

    <%# Sidebar — my recent activity %>
    <div class="space-y-6">
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
        <h3 class="text-sm font-semibold text-slate-900 mb-3">Recent activity</h3>
        <%= render "shared/activity_timeline", activity_logs: @recent_activity %>
      </div>
    </div>
  </div>
<% end %>
