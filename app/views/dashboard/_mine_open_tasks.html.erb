<div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-slate-900">My open tasks</h2>
    <%= link_to "View all", tasks_path(consultant_id: current_user.id), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>
  <% if my_tasks.any? %>
    <div class="space-y-2">
      <% my_tasks.each do |task| %>
        <% overdue = task.due_date < Date.current %>
        <div class="flex items-center justify-between text-sm border-b border-slate-100 pb-2 <%= overdue ? 'bg-red-50 -mx-2 px-2 rounded' : '' %>">
          <div>
            <%= link_to task.title, task, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
            <span class="text-slate-400 ml-1">due <%= task.due_date.strftime("%b %d") %></span>
            <% if overdue %>
              <span class="text-red-500 text-xs ml-1">(overdue)</span>
            <% end %>
          </div>
          <%= status_badge(task.status) %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500">No open tasks.</p>
  <% end %>
</div>
