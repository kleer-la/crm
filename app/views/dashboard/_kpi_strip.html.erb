<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
    <dt class="text-sm font-medium text-slate-500">Team pipeline value</dt>
    <dd class="mt-1 text-2xl font-semibold text-slate-900"><%= currency(@team_pipeline_value) %></dd>
  </div>
  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
    <dt class="text-sm font-medium text-slate-500">Proposals sent this month</dt>
    <dd class="mt-1 text-2xl font-semibold text-slate-900"><%= @team_proposals_sent %></dd>
  </div>
  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
    <dt class="text-sm font-medium text-slate-500">Proposals won this month</dt>
    <dd class="mt-1 text-2xl font-semibold text-slate-900"><%= @team_proposals_won %></dd>
  </div>
</div>
