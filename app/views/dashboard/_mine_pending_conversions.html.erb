<% if my_pending_conversions.any? %>
  <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
    <h2 class="text-sm font-semibold text-slate-900 mb-3">Pending conversions</h2>
    <div class="space-y-2">
      <% my_pending_conversions.each do |proposal| %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3">
          <p class="text-sm text-yellow-800">
            <%= link_to proposal.title, proposal, class: "font-semibold text-yellow-900 underline hover:text-yellow-700" %>
            is Won but linked Prospect
            <%= link_to proposal.linkable.company_name, proposal.linkable, class: "text-yellow-900 underline hover:text-yellow-700" %>
            has not been converted.
          </p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
