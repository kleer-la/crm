<%# Usage: render "shared/sortable_header", label: "Name", field: "company_name", current_sort: params[:sort], current_dir: params[:dir], url: prospects_path %>
<% active = current_sort == field.to_s %>
<% next_dir = (active && current_dir == "asc") ? "desc" : "asc" %>
<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
  <%= link_to url_for(sort: field, dir: next_dir, **request.query_parameters.except("sort", "dir")), class: "group inline-flex items-center gap-1 hover:text-gray-700" do %>
    <%= label %>
    <% if active %>
      <span class="text-blue-600"><%= current_dir == "asc" ? "↑" : "↓" %></span>
    <% else %>
      <span class="text-gray-300 group-hover:text-gray-400">↕</span>
    <% end %>
  <% end %>
</th>
