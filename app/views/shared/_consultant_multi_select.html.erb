<%# Pill-based multi-select for collaborating consultants %>
<%# Usage: render "shared/consultant_multi_select", form: f, field: :collaborating_consultant_ids, label: "Collaborating Consultants" %>
<% consultants = User.assignable.order(:name) %>
<% selected_ids = form.object.send(field).map(&:to_s) %>
<% field_name = "#{form.object_name}[#{field}][]" %>

<div class="mb-4" data-controller="multi-select">

  <%# Label %>
  <div class="flex items-center gap-1.5 mb-1">
    <%= form.label field, label, class: "block text-sm font-medium text-slate-700" %>
    <span class="text-xs text-slate-400 font-normal">optional</span>
  </div>

  <%# Pre-existing hidden inputs — controller re-hydrates selected state from these on connect() %>
  <% selected_ids.each do |id| %>
    <input type="hidden"
           name="<%= field_name %>"
           value="<%= id %>"
           data-collaborator-id="<%= id %>">
  <% end %>
  <% if selected_ids.empty? %>
    <input type="hidden"
           name="<%= field_name %>"
           value=""
           data-multi-select-target="blank">
  <% end %>

  <%# Input area: pills + search input %>
  <div class="min-h-[38px] flex flex-wrap items-center gap-1.5 px-2.5 py-1.5 rounded-md border border-slate-300 bg-white cursor-text focus-within:ring-2 focus-within:ring-indigo-500 focus-within:border-indigo-500"
       data-action="click->multi-select#onInputClick">

    <%# Pills container — pre-render selected pills for edit forms %>
    <div class="contents" data-multi-select-target="pills">
      <% selected_ids.each do |id| %>
        <% consultant = consultants.find { |c| c.id.to_s == id } %>
        <% next unless consultant %>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"
              data-collaborator-id="<%= id %>">
          <%= consultant.display_name %>
          <button type="button"
                  data-action="click->multi-select#removePill"
                  data-id="<%= id %>"
                  aria-label="Remove <%= consultant.display_name %>"
                  class="text-indigo-500 hover:text-indigo-700 leading-none focus:outline-none">&times;</button>
        </span>
      <% end %>
    </div>

    <input type="text"
           placeholder="Search consultants…"
           autocomplete="off"
           class="flex-1 min-w-[120px] text-sm text-slate-700 placeholder-slate-400 border-0 p-0 focus:ring-0 focus:outline-none bg-transparent"
           data-multi-select-target="input"
           data-field-name="<%= field_name %>"
           data-action="input->multi-select#onInput keydown->multi-select#onKeydown focus->multi-select#openDropdown click->multi-select#onInputClick">
  </div>

  <%# Dropdown %>
  <div class="relative">
    <div class="hidden absolute z-10 w-full mt-1 bg-white border border-slate-200 rounded-md shadow-lg max-h-48 overflow-y-auto"
         data-multi-select-target="dropdown"
         aria-expanded="false"
         role="listbox">

      <% consultants.each do |consultant| %>
        <div class="px-3 py-2 text-sm text-slate-700 cursor-pointer hover:bg-indigo-50"
             role="option"
             data-multi-select-target="option"
             data-value="<%= consultant.id %>"
             data-label="<%= consultant.display_name %>"
             data-action="click->multi-select#selectOption">
          <%= consultant.display_name %>
        </div>
      <% end %>

      <div class="hidden px-3 py-2 text-sm text-slate-400 italic" data-multi-select-target="noResults">
        No results
      </div>
    </div>
  </div>

</div>
