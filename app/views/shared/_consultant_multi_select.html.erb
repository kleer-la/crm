<%# Multi consultant select for collaborating consultants %>
<%# Usage: render "shared/consultant_multi_select", form: f, field: :collaborating_consultant_ids, label: "Collaborating Consultants" %>
<% consultants = User.assignable.order(:name) %>

<div class="mb-4">
  <div class="flex items-center gap-1.5 mb-1">
    <%= form.label field, label, class: "block text-sm font-medium text-slate-700" %>
    <span class="text-xs text-slate-400 font-normal">optional</span>
  </div>
  <%= form.collection_check_boxes field, consultants, :id, :display_name do |b| %>
    <div class="flex items-center gap-2 py-1">
      <%= b.check_box class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
      <%= b.label class: "text-sm text-slate-700" %>
    </div>
  <% end %>
</div>
