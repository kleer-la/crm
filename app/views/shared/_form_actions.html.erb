<%# Usage: render "shared/form_actions", form: f, cancel_path: prospects_path %>
<div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200 mt-6">
  <% if defined?(cancel_path) && cancel_path %>
    <%= link_to "Cancel", cancel_path, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
  <% end %>
  <%= form.submit class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 cursor-pointer" %>
</div>
