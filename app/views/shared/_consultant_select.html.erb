<%# Single consultant select %>
<%# Usage: render "shared/consultant_select", form: f, field: :responsible_consultant_id, label: "Responsible Consultant", required: true %>
<% required ||= false %>
<% consultants = User.assignable.order(:name) %>

<div class="mb-4">
  <div class="flex items-center gap-1.5 mb-1">
    <%= form.label field, label, class: "block text-sm font-medium text-slate-700" %>
    <% unless required %><span class="text-xs text-slate-400 font-normal">optional</span><% end %>
  </div>
  <%= form.collection_select field, consultants, :id, :display_name,
    { include_blank: "Select a consultant..." },
    class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
    required: required %>

  <% if form.object&.errors&.[](field)&.any? %>
    <p class="mt-1 text-xs text-red-600"><%= form.object.errors[field].first %></p>
  <% end %>
</div>
