<%# Usage: render "shared/touchpoint_form", record: @prospect %>
<%# record must respond to activity_logs and be a loggable type %>
<div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
  <h3 class="text-sm font-semibold text-slate-900 mb-3">Log a touchpoint</h3>

  <%= form_with url: touchpoints_path, method: :post, class: "space-y-3" do |f| %>
    <%= f.hidden_field :loggable_type, value: record.class.name %>
    <%= f.hidden_field :loggable_id, value: record.id %>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Type</label>
      <%= f.select :touchpoint_type,
        [["Call", "call"], ["Email", "email"], ["Meeting", "meeting"], ["Note", "note"]],
        { prompt: "Select type..." },
        class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
        required: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Description</label>
      <%= f.text_area :content, rows: 2,
        class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20",
        required: true,
        placeholder: "What happened?" %>
    </div>

    <%= f.submit "Log touchpoint", class: "px-3 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700 cursor-pointer" %>
  <% end %>
</div>
