<% if flash[:notice] %>
  <div class="mb-4 flex items-start gap-3 bg-green-50 border border-green-100 rounded-lg overflow-hidden" data-controller="flash">
    <div class="w-1 self-stretch bg-green-500 flex-shrink-0"></div>
    <svg class="mt-3 h-5 w-5 text-green-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
    </svg>
    <p class="flex-1 py-3 text-sm text-green-800"><%= flash[:notice] %></p>
    <button type="button" class="mt-2 mr-2 p-1 text-green-500 hover:text-green-700 rounded" data-action="flash#dismiss">
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
      </svg>
    </button>
  </div>
<% end %>
<% if flash[:alert] %>
  <div class="mb-4 flex items-start gap-3 bg-red-50 border border-red-100 rounded-lg overflow-hidden" data-controller="flash">
    <div class="w-1 self-stretch bg-red-500 flex-shrink-0"></div>
    <svg class="mt-3 h-5 w-5 text-red-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
    </svg>
    <p class="flex-1 py-3 text-sm text-red-800"><%= flash[:alert] %></p>
    <button type="button" class="mt-2 mr-2 p-1 text-red-500 hover:text-red-700 rounded" data-action="flash#dismiss">
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
      </svg>
    </button>
  </div>
<% end %>
