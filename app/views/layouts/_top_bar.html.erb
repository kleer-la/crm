<div class="sticky top-0 z-10 bg-white shadow">
  <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
    <%# Mobile menu button %>
    <button type="button" class="lg:hidden -ml-2 p-2 text-gray-500 hover:text-gray-900" data-action="sidebar#toggle">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <%# Global Search %>
    <div class="flex-1 max-w-lg mx-4" id="global-search" data-controller="search">
      <div class="relative">
        <%= form_with url: search_path, method: :get, data: { turbo_frame: "search-results", action: "input->search#search" } do |f| %>
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search prospects, customers, proposals..."
                 autocomplete="off"
                 data-search-target="input"
                 data-action="focus->search#showResults blur->search#delayHideResults"
                 class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm pl-10 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
        <% end %>
        <div class="hidden absolute top-full left-0 right-0 mt-1 bg-white rounded-xl shadow-lg ring-1 ring-slate-200 z-30 max-h-96 overflow-y-auto"
             data-search-target="results">
          <turbo-frame id="search-results">
          </turbo-frame>
        </div>
      </div>
    </div>

    <%# Right side: notification bell + user menu %>
    <div class="flex items-center gap-4">
      <%# Notification bell placeholder %>
      <button type="button" class="p-1 text-slate-400 hover:text-slate-500 relative">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
        </svg>
      </button>

      <%# User menu %>
      <div class="relative" data-controller="dropdown">
        <button type="button" class="flex items-center gap-2 text-sm text-slate-700 hover:text-slate-900" data-action="dropdown#toggle">
          <% if current_user.avatar_url.present? %>
            <img src="<%= current_user.avatar_url %>" alt="" class="h-8 w-8 rounded-full">
          <% else %>
            <span class="h-8 w-8 rounded-full bg-slate-200 flex items-center justify-center text-xs font-medium text-slate-700">
              <%= current_user.name.first(2).upcase %>
            </span>
          <% end %>
          <span class="hidden sm:inline"><%= current_user.name %></span>
        </button>

        <div class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg ring-1 ring-slate-200 py-1 z-20" data-dropdown-target="menu">
          <div class="px-4 py-2 text-xs text-slate-500"><%= current_user.role.capitalize %></div>
          <hr class="my-1">
          <%= button_to "Sign Out", logout_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
        </div>
      </div>
    </div>
  </div>
</div>
