<div class="flex flex-col flex-1 bg-slate-700">
  <div class="flex items-center h-16 flex-shrink-0 px-4 bg-slate-800">
    <%= link_to root_path, class: "text-white font-bold text-lg" do %>
      PaToRiCo CRM
    <% end %>
  </div>

  <nav class="flex-1 px-2 py-4 space-y-1">
    <%= sidebar_link "Dashboard", root_path, "dashboard" %>
    <%= sidebar_link "Tasks", tasks_path, "tasks" %>
    <%= sidebar_link "Proposals", proposals_path, "proposals" %>
    <%= sidebar_link "Pipeline", pipeline_path, "pipeline" %>
    <%= sidebar_link "Prospects", prospects_path, "prospects" %>
    <%= sidebar_link "Customers", customers_path, "customers" %>
    <%= sidebar_link "Conversations", conversations_path, "conversations" %>
    <%= sidebar_link "Reports", "#", "reports" %>

    <% if current_user&.admin? %>
      <div class="pt-4 mt-4 border-t border-slate-600">
        <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Admin</p>
        <%= sidebar_link "Users", admin_users_path, "users" %>
        <%= sidebar_link "Import data", new_admin_import_path, "imports" %>
      </div>
    <% end %>
  </nav>

  <% last_deployment = Deployment.recent.first %>
  <% if last_deployment %>
    <div class="px-4 py-3 border-t border-slate-600">
      <%= link_to system_deployments_path, class: "text-xs text-slate-400 hover:text-slate-300" do %>
        Deployed: <%= last_deployment.deployed_at.strftime("%Y-%m-%d %H:%M") %>
      <% end %>
    </div>
  <% end %>
</div>
