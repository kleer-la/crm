<div class="flex flex-col flex-1 bg-gray-800">
  <div class="flex items-center h-16 flex-shrink-0 px-4 bg-gray-900">
    <%= link_to root_path, class: "text-white font-bold text-lg" do %>
      Consulting CRM
    <% end %>
  </div>

  <nav class="flex-1 px-2 py-4 space-y-1">
    <%= sidebar_link "Dashboard", root_path, "dashboard" %>
    <%= sidebar_link "Prospects", prospects_path, "prospects" %>
    <%= sidebar_link "Customers", "#", "customers" %>
    <%= sidebar_link "Proposals", "#", "proposals" %>
    <%= sidebar_link "Tasks", "#", "tasks" %>
    <%= sidebar_link "Pipeline", "#", "pipeline" %>
    <%= sidebar_link "Reports", "#", "reports" %>

    <% if current_user&.admin? %>
      <div class="pt-4 mt-4 border-t border-gray-700">
        <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Admin</p>
        <%= sidebar_link "Users", admin_users_path, "users" %>
      </div>
    <% end %>
  </nav>
</div>
