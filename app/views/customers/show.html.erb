<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= @customer.company_name %></h1>
      <div class="mt-1 flex items-center gap-2">
        <%= status_badge(@customer.status) %>
      </div>
    </div>
    <div class="mt-4 sm:mt-0 flex gap-2">
      <%= link_to "Edit", edit_customer_path(@customer), class: "px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Details column %>
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Details</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-sm font-medium text-slate-500">Industry</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @customer.industry.presence || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Country</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @customer.country.presence || "—" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Total revenue</dt>
            <dd class="mt-1 text-sm text-slate-900 font-semibold"><%= currency(@customer.total_revenue) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Customer since</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @customer.date_became_customer&.strftime("%b %d, %Y") %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-slate-500">Last activity</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @customer.last_activity_date&.strftime("%b %d, %Y") %></dd>
          </div>
        </dl>
      </div>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-slate-900">Contacts</h2>
          <%= link_to "Add contact", new_customer_contact_path(@customer), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        </div>
        <% if @contacts.any? %>
          <div class="space-y-3">
            <% @contacts.each do |contact| %>
              <div class="flex items-center justify-between border border-slate-200 rounded-lg p-3">
                <div>
                  <p class="text-sm font-medium text-slate-900">
                    <%= contact.name %>
                    <% if contact.primary? %>
                      <span class="ml-1 inline-block px-2 py-0.5 text-xs font-semibold rounded-full bg-indigo-100 text-indigo-700">Primary</span>
                    <% end %>
                  </p>
                  <p class="text-sm text-slate-500"><%= contact.role_title %></p>
                  <p class="text-sm text-slate-500">
                    <%= mail_to contact.email, contact.email, class: "text-indigo-600 hover:text-indigo-900" %>
                    <% if contact.phone.present? %>
                      &middot; <%= contact.phone %>
                    <% end %>
                  </p>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <%= link_to "Edit", edit_customer_contact_path(@customer, contact), class: "text-sm text-slate-600 hover:text-slate-900" %>
                  <%= link_to "Remove", customer_contact_path(@customer, contact), class: "text-sm text-red-600 hover:text-red-800", data: { turbo_method: :delete, turbo_confirm: "Remove this contact?" } %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">No contacts yet.</p>
        <% end %>
      </div>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-slate-900">Consultants</h2>
        </div>
        <dl class="space-y-3">
          <div>
            <dt class="text-sm font-medium text-slate-500">Responsible</dt>
            <dd class="mt-1 text-sm text-slate-900"><%= @customer.responsible_consultant.display_name %></dd>
          </div>
          <% if @customer.collaborating_consultants.any? %>
            <div>
              <dt class="text-sm font-medium text-slate-500">Collaborators</dt>
              <dd class="mt-1 text-sm text-slate-900">
                <%= @customer.collaborating_consultants.map(&:display_name).join(", ") %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>

      <%# Full history timeline (8.7) %>
      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">History</h2>
        <%= render "customers/history_timeline", customer: @customer %>
      </div>
    </div>

    <%# Sidebar column %>
    <div class="space-y-6">
      <%= render "shared/touchpoint_form", record: @customer %>

      <turbo-frame id="<%= dom_id(@customer, :tasks) %>" class="block">
        <%= render "tasks/section", linkable: @customer %>
      </turbo-frame>

      <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
        <h3 class="text-sm font-semibold text-slate-900 mb-3">Recent activity</h3>
        <%= render "shared/activity_timeline", activity_logs: @customer.activity_logs.includes(:user).order(occurred_at: :desc).limit(20) %>
      </div>
    </div>
  </div>
</div>
