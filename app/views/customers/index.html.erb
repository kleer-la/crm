<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Customers</h1>
    <%= link_to "New customer", new_customer_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700" %>
  </div>

  <%= render "shared/filter_bar", url: customers_path do |f| %>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Search</label>
      <%= f.text_field :search, value: params[:search], placeholder: "Company name...", class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Status</label>
      <%= f.select :status, Customer.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "All" }, value: params[:status], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Consultant</label>
      <%= f.select :consultant_id, User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { include_blank: "All" }, value: params[:consultant_id], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
  <% end %>

  <turbo-frame id="results">
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <%= render "shared/sortable_header", label: "Company", field: "company_name", current_sort: params[:sort], current_dir: params[:dir], url: customers_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Country</th>
            <%= render "shared/sortable_header", label: "Status", field: "status", current_sort: params[:sort], current_dir: params[:dir], url: customers_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Strategy</th>
            <%= render "shared/sortable_header", label: "Industry", field: "industry", current_sort: params[:sort], current_dir: params[:dir], url: customers_path %>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Responsible</th>
            <%= render "shared/sortable_header", label: "Total revenue", field: "total_revenue", current_sort: params[:sort], current_dir: params[:dir], url: customers_path %>
            <%= render "shared/sortable_header", label: "Last activity", field: "last_activity_date", current_sort: params[:sort], current_dir: params[:dir], url: customers_path %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          <% @customers.each do |customer| %>
            <tr class="hover:bg-indigo-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold flex-shrink-0">
                    <%= customer.company_name.first(2).upcase %>
                  </span>
                  <%= link_to customer.company_name, customer, class: "text-indigo-600 hover:text-indigo-900 font-medium", data: { turbo_frame: "_top" } %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= customer.country.presence || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(customer.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= customer.strategy&.humanize || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= customer.industry.presence || "—" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= customer.responsible_consultant.display_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                <%= currency(customer.total_revenue) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= customer.last_activity_date&.strftime("%b %d, %Y") %>
              </td>
            </tr>
          <% end %>

          <% if @customers.empty? %>
            <tr>
              <td colspan="8" class="px-6 py-16 text-center">
                <svg class="mx-auto h-10 w-10 text-slate-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <p class="text-sm font-medium text-slate-600 mb-1">No customers found</p>
                <p class="text-xs text-slate-400 mb-4">Try adjusting your filters or add a new customer.</p>
                <%= link_to "Add your first customer", new_customer_path, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </turbo-frame>
</div>
