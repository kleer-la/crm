<%
  # Gather all related records into a unified timeline
  entries = []

  customer.proposals.includes(:responsible_consultant).each do |proposal|
    entries << { date: proposal.created_at, type: :proposal, record: proposal }
  end

  customer.tasks.includes(:assigned_to).each do |task|
    entries << { date: task.created_at, type: :task, record: task }
  end

  customer.activity_logs.includes(:user).each do |log|
    entries << { date: log.created_at, type: :activity, record: log }
  end

  entries.sort_by! { |e| e[:date] }.reverse!
%>

<div class="flow-root">
  <% if entries.any? %>
    <ul class="-mb-8">
      <% entries.each_with_index do |entry, index| %>
        <li>
          <div class="relative pb-8">
            <% unless index == entries.size - 1 %>
              <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
            <% end %>
            <div class="relative flex space-x-3">
              <div>
                <% case entry[:type] %>
                <% when :proposal %>
                  <span class="h-8 w-8 rounded-full bg-purple-500 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                  </span>
                <% when :task %>
                  <span class="h-8 w-8 rounded-full bg-green-500 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                  </span>
                <% when :activity %>
                  <% log = entry[:record] %>
                  <% if log.system? %>
                    <span class="h-8 w-8 rounded-full bg-gray-400 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </span>
                  <% else %>
                    <span class="h-8 w-8 rounded-full bg-indigo-500 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                      </svg>
                    </span>
                  <% end %>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <% case entry[:type] %>
                <% when :proposal %>
                  <% proposal = entry[:record] %>
                  <div class="text-sm text-gray-500">
                    <span class="font-medium text-gray-900">Proposal:</span>
                    <%= link_to proposal.title, proposal, class: "text-indigo-600 hover:text-indigo-900" if defined?(proposal_path) %>
                    <span class="inline-block px-2 py-0.5 text-xs font-semibold rounded-full bg-purple-100 text-purple-800 ml-1"><%= proposal.status.humanize %></span>
                    <span class="whitespace-nowrap ml-1"><%= time_ago_in_words(proposal.created_at) %> ago</span>
                  </div>
                  <p class="mt-1 text-sm text-gray-700">
                    Assigned to <%= proposal.responsible_consultant.display_name %>
                    <% if proposal.estimated_value.present? %>
                      &middot; Est. <%= number_to_currency(proposal.estimated_value) %>
                    <% end %>
                  </p>
                <% when :task %>
                  <% task = entry[:record] %>
                  <div class="text-sm text-gray-500">
                    <span class="font-medium text-gray-900">Task:</span>
                    <%= task.title %>
                    <span class="inline-block px-2 py-0.5 text-xs font-semibold rounded-full bg-green-100 text-green-800 ml-1"><%= task.status.humanize %></span>
                    <span class="whitespace-nowrap ml-1"><%= time_ago_in_words(task.created_at) %> ago</span>
                  </div>
                  <p class="mt-1 text-sm text-gray-700">
                    Assigned to <%= task.assigned_to.display_name %>
                    &middot; Due <%= task.due_date&.strftime("%b %d, %Y") %>
                  </p>
                <% when :activity %>
                  <% log = entry[:record] %>
                  <div class="text-sm text-gray-500">
                    <span class="font-medium text-gray-900"><%= log.user&.display_name || "System" %></span>
                    <% if log.touchpoint? %>
                      logged a <span class="font-medium"><%= log.touchpoint_type %></span>
                    <% end %>
                    <span class="whitespace-nowrap ml-1"><%= time_ago_in_words(log.created_at) %> ago</span>
                  </div>
                  <p class="mt-1 text-sm text-gray-700"><%= log.content %></p>
                <% end %>
              </div>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-gray-500 text-center py-4">No history yet.</p>
  <% end %>
</div>
