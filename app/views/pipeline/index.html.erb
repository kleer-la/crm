<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Pipeline</h1>
  </div>

  <%# Summary Bar %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
      <dt class="text-sm font-medium text-slate-500">Total pipeline value</dt>
      <dd class="mt-1 text-2xl font-semibold text-slate-900"><%= currency(@summary[:pipeline_value]) %></dd>
    </div>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
      <dt class="text-sm font-medium text-slate-500">Open proposals</dt>
      <dd class="mt-1 text-2xl font-semibold text-slate-900"><%= @summary[:open_proposal_count] %></dd>
    </div>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl p-4">
      <dt class="text-sm font-medium text-slate-500">Active prospects</dt>
      <dd class="mt-1 text-2xl font-semibold text-slate-900"><%= @summary[:active_prospect_count] %></dd>
    </div>
  </div>

  <%# Filter Controls %>
  <%= render "shared/filter_bar", url: pipeline_path do |f| %>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Consultant</label>
      <%= f.select :consultant_id, User.assignable.order(:name).map { |u| [u.display_name, u.id] }, { include_blank: "All" }, value: params[:consultant_id], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Prospect status</label>
      <%= f.select :prospect_status, [["New", "new_prospect"], ["Contacted", "contacted"], ["Qualified", "qualified"]], { include_blank: "All" }, value: params[:prospect_status], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Proposal status</label>
      <%= f.select :proposal_status, [["Draft", "draft"], ["Sent", "sent"], ["Under Review", "under_review"]], { include_blank: "All" }, value: params[:proposal_status], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Close date from</label>
      <%= f.date_field :close_date_from, value: params[:close_date_from], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Close date to</label>
      <%= f.date_field :close_date_to, value: params[:close_date_to], class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Value min ($)</label>
      <%= f.number_field :value_min, value: params[:value_min], min: 0, step: 1000, class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 mb-1">Value max ($)</label>
      <%= f.number_field :value_max, value: params[:value_max], min: 0, step: 1000, class: "block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20" %>
    </div>
  <% end %>

  <%# Active prospects %>
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-slate-900 mb-3">Active prospects</h2>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Company</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Consultant</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Est. value</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Last activity</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          <% @prospects.each do |prospect| %>
            <tr class="hover:bg-indigo-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to prospect.company_name, prospect, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(prospect.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= prospect.responsible_consultant.display_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                <%= currency(prospect.estimated_value) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= prospect.last_activity_date&.strftime("%b %d, %Y") || "—" %>
              </td>
            </tr>
          <% end %>
          <% if @prospects.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-sm text-slate-500">No active prospects found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Open proposals %>
  <div>
    <h2 class="text-lg font-semibold text-slate-900 mb-3">Open proposals</h2>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Title</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Linked to</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Consultant</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Est. value</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Expected close</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          <% @proposals.each do |proposal| %>
            <% overdue_close = proposal.expected_close_date.present? && proposal.expected_close_date < Date.current %>
            <tr class="<%= overdue_close ? 'bg-red-50 hover:bg-red-100' : 'hover:bg-indigo-50' %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to proposal.title, proposal, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= link_to proposal.linkable.company_name, polymorphic_path(proposal.linkable), class: "text-indigo-600 hover:text-indigo-900" %>
                <span class="text-xs text-slate-400">(<%= proposal.linkable_type %>)</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= status_badge(proposal.status) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                <%= proposal.responsible_consultant.display_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900">
                <%= currency(proposal.estimated_value) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm <%= overdue_close ? 'text-red-600 font-semibold' : 'text-slate-500' %>">
                <%= proposal.expected_close_date&.strftime("%b %d, %Y") || "—" %>
                <% if overdue_close %>
                  <span class="text-xs text-red-500 ml-1">(overdue)</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @proposals.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-8 text-center text-sm text-slate-500">No open proposals found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
