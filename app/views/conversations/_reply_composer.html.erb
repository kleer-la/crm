<div id="reply_composer" class="border-t border-slate-200 p-4"
     data-controller="reply-composer">
  <% canned_responses = CannedResponse.ordered %>
  <% if canned_responses.any? %>
    <div class="mb-2 relative" data-reply-composer-target="cannedMenu">
      <button type="button"
              class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-slate-500 hover:text-slate-700 hover:bg-slate-100 rounded-md"
              data-action="click->reply-composer#toggleCanned"
              data-reply-composer-target="cannedToggle">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
        Quick replies
      </button>
      <div class="hidden absolute bottom-full left-0 mb-1 w-72 bg-white rounded-lg shadow-lg ring-1 ring-slate-200 py-1 z-10 max-h-48 overflow-y-auto"
           data-reply-composer-target="cannedDropdown">
        <% canned_responses.each do |cr| %>
          <button type="button"
                  class="w-full text-left px-3 py-2 text-sm hover:bg-slate-50"
                  data-action="click->reply-composer#selectCanned"
                  data-content="<%= cr.content %>">
            <span class="font-medium text-slate-700"><%= cr.name %></span>
            <span class="block text-xs text-slate-400 truncate"><%= cr.content %></span>
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= form_with(model: [conversation, message || Message.new], url: conversation_messages_path(conversation),
                class: "flex gap-2 items-end", html: { multipart: true },
                data: { reply_composer_target: "form", action: "keydown.enter->reply-composer#submitOnEnter turbo:submit-end->reply-composer#resetAfterSubmit" }) do |f| %>
    <div class="flex-1 space-y-2">
      <!-- File preview -->
      <div class="hidden items-center gap-2 px-2 py-1 bg-slate-50 rounded-lg text-sm text-slate-600"
           data-reply-composer-target="filePreview">
        <span data-reply-composer-target="fileName"></span>
        <button type="button" class="text-slate-400 hover:text-red-500" data-action="click->reply-composer#clearFile">&times;</button>
      </div>

      <textarea name="message[content]" rows="1"
                class="block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm resize-none focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                placeholder="Type a message..."
                data-reply-composer-target="input"
                data-action="input->reply-composer#resize"></textarea>
    </div>
    <div class="flex gap-1">
      <%= f.hidden_field :message_type, value: "text", data: { reply_composer_target: "messageType" } %>
      <input type="file" name="message[file]" class="hidden"
             data-reply-composer-target="fileInput"
             data-action="change->reply-composer#fileSelected"
             accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx">

      <button type="button"
              class="px-2 py-2 text-slate-400 hover:text-slate-600 rounded-xl"
              data-action="click->reply-composer#pickFile"
              data-reply-composer-target="fileButton"
              title="Attach file">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
      </button>
      <button type="button"
              class="px-3 py-2 text-sm font-medium rounded-xl text-slate-500 hover:bg-slate-100"
              data-action="click->reply-composer#toggleNote"
              data-reply-composer-target="noteToggle"
              title="Add internal note">
        Note
      </button>
      <button type="submit"
              class="px-4 py-2 text-sm font-medium rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-50"
              data-reply-composer-target="submit">
        Send
      </button>
    </div>
  <% end %>
</div>
