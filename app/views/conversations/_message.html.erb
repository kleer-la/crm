<div id="<%= dom_id(message) %>" class="flex <%= message.outbound? ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-[75%] rounded-2xl px-4 py-2 <%= message_bubble_classes(message) %>">
    <% if message.note? %>
      <p class="text-xs font-medium mb-1 text-amber-600">Note</p>
      <p class="text-sm whitespace-pre-wrap"><%= message.content %></p>
    <% elsif message.text? %>
      <p class="text-sm whitespace-pre-wrap"><%= message.content %></p>
    <% else %>
      <p class="text-xs font-medium mb-1 <%= message.outbound? ? 'text-indigo-200' : 'text-slate-400' %>">
        <%= message.message_type.capitalize %>
      </p>
      <%= render "conversations/media_content", message: message %>
    <% end %>
    <p class="text-xs mt-1 <%= message.outbound? ? 'text-indigo-200' : 'text-slate-400' %>">
      <%= message.sent_at.strftime("%b %d, %H:%M") %>
    </p>
  </div>
</div>
