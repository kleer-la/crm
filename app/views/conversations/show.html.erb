<div class="px-4 sm:px-6 lg:px-8 py-8"
     data-controller="notification"
     data-notification-conversation-id-value="<%= @conversation.id %>">
  <audio id="notification-sound" preload="auto" src="/notification.wav"></audio>

  <!-- Notification permission banner -->
  <div id="notification-banner" class="mb-4 hidden">
    <div class="rounded-lg bg-indigo-50 p-3 flex items-center justify-between">
      <p class="text-sm text-indigo-700">Enable desktop notifications to get alerts for new messages.</p>
      <button onclick="Notification.requestPermission().then(() => this.closest('#notification-banner').remove())"
              class="text-sm font-medium text-indigo-600 hover:text-indigo-500 ml-4">
        Enable
      </button>
    </div>
  </div>
  <script>
    if ("Notification" in window && Notification.permission === "default") {
      document.getElementById("notification-banner").classList.remove("hidden")
    }
  </script>

  <!-- Header -->
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full flex-shrink-0 <%= platform_badge_bg(@conversation.platform) %>">
        <span class="text-xs font-bold text-white"><%= @conversation.platform_label %></span>
      </span>
      <div>
        <h1 class="text-2xl font-bold text-slate-900"><%= @conversation.display_name %></h1>
        <p class="text-sm text-slate-500">
          <%= @conversation.platform.capitalize %> · <%= @conversation.external_contact_id %>
          · <%= @conversation.status.capitalize %>
        </p>
      </div>
    </div>
    <div class="mt-4 sm:mt-0 flex items-center gap-2">
      <% if @conversation.open? %>
        <%= button_to "Close", close_conversation_path(@conversation), method: :patch, class: "inline-flex items-center px-3 py-1.5 border border-slate-300 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50" %>
      <% else %>
        <%= button_to "Reopen", reopen_conversation_path(@conversation), method: :patch, class: "inline-flex items-center px-3 py-1.5 border border-green-300 rounded-md text-sm font-medium text-green-700 bg-white hover:bg-green-50" %>
      <% end %>
      <%= link_to "Back to inbox", conversations_path, class: "inline-flex items-center px-4 py-2 border border-slate-300 rounded-md text-sm font-medium text-slate-700 bg-white hover:bg-slate-50" %>
    </div>
  </div>

  <!-- Assignment & linking -->
  <div class="mb-4 flex flex-wrap items-center gap-4">
    <!-- Assignment -->
    <%= form_with url: assign_conversation_path(@conversation), method: :patch, class: "flex items-center gap-2" do |f| %>
      <label class="text-sm text-slate-500">Assigned to</label>
      <%= f.select :assigned_user_id, User.where(active: true).order(:name).pluck(:name, :id),
          { include_blank: "Unassigned", selected: @conversation.assigned_user_id },
          { class: "text-sm rounded-md border-slate-300", onchange: "this.form.requestSubmit()" } %>
    <% end %>

    <!-- Linking -->
    <% if @conversation.linkable %>
      <span class="text-sm text-slate-500">
        Linked to
        <% if @conversation.linkable_type == "Customer" %>
          <%= link_to @conversation.linkable.company_name, customer_path(@conversation.linkable), class: "text-indigo-600 hover:underline" %>
        <% else %>
          <%= link_to @conversation.linkable.company_name, prospect_path(@conversation.linkable), class: "text-indigo-600 hover:underline" %>
        <% end %>
      </span>
      <%= button_to "Unlink", link_conversation_path(@conversation), method: :patch, params: { linkable_type: nil, linkable_id: nil }, class: "text-xs text-slate-400 hover:text-red-500" %>
    <% else %>
      <%= form_with url: link_conversation_path(@conversation), method: :patch, class: "flex items-center gap-2" do %>
        <label class="text-sm text-slate-500">Link to</label>
        <select name="linkable_combo"
                class="text-sm rounded-md border-slate-300"
                onchange="
                  var val = this.value.split('-');
                  this.form.querySelector('input[name=linkable_type]').value = val[0] || '';
                  this.form.querySelector('input[name=linkable_id]').value = val[1] || '';
                  this.form.requestSubmit();
                ">
          <option value="">Select...</option>
          <optgroup label="Customers">
            <% Customer.order(:company_name).each do |c| %>
              <option value="Customer-<%= c.id %>"><%= c.company_name %></option>
            <% end %>
          </optgroup>
          <optgroup label="Prospects">
            <% Prospect.where.not(status: :converted).order(:company_name).each do |p| %>
              <option value="Prospect-<%= p.id %>"><%= p.company_name %></option>
            <% end %>
          </optgroup>
        </select>
        <input type="hidden" name="linkable_type" value="">
        <input type="hidden" name="linkable_id" value="">
      <% end %>
    <% end %>
  </div>

  <!-- Messages + Contact panel -->
  <div class="flex gap-4">
    <!-- Messages -->
    <div class="flex-1 min-w-0 bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden">
      <div class="p-4 sm:p-6 space-y-4 max-h-[600px] overflow-y-auto" id="messages"
           data-controller="scroll"
           data-scroll-target="container">
        <%= turbo_stream_from @conversation %>

        <% if @has_older && @messages.any? %>
          <turbo-frame id="older-messages" src="<%= older_messages_conversation_path(@conversation, before: @messages.first.sent_at.iso8601(6)) %>" loading="lazy">
            <button class="w-full text-center text-sm text-indigo-600 hover:text-indigo-800 py-2">
              Load earlier messages
            </button>
          </turbo-frame>
        <% end %>

        <% @messages.each do |message| %>
          <%= render "conversations/message", message: message %>
        <% end %>

        <% if @messages.empty? %>
          <p class="text-center text-slate-400 py-8">No messages in this conversation.</p>
        <% end %>
      </div>

      <!-- Reply composer -->
      <%= render "conversations/reply_composer", conversation: @conversation, message: nil %>
    </div>

    <!-- Contact info panel -->
    <div class="hidden lg:block w-72 flex-shrink-0">
      <%= render "conversations/contact_panel", conversation: @conversation %>
    </div>
  </div>
</div>
