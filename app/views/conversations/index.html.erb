<div class="px-4 sm:px-6 lg:px-8 py-8">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Conversations</h1>
  </div>

  <!-- Search -->
  <div class="mb-4">
    <%= form_with url: conversations_path, method: :get do |f| %>
      <input type="text" name="q" value="<%= params[:q] %>"
             class="block w-full sm:w-80 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
             placeholder="Search conversations..."
             autocomplete="off">
      <% if params[:platform].present? %>
        <%= f.hidden_field :platform, value: params[:platform] %>
      <% end %>
    <% end %>
  </div>

  <!-- Status filters -->
  <div class="mb-3 flex gap-3">
    <% current_status = params[:status] || "open" %>
    <%= link_to "Open", conversations_path(status: "open", platform: params[:platform], q: params[:q]),
      class: "px-3 py-1.5 text-sm font-medium rounded-md #{current_status == 'open' ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
    <%= link_to "Closed", conversations_path(status: "closed", platform: params[:platform], q: params[:q]),
      class: "px-3 py-1.5 text-sm font-medium rounded-md #{current_status == 'closed' ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
    <%= link_to "All", conversations_path(status: "all", platform: params[:platform], q: params[:q]),
      class: "px-3 py-1.5 text-sm font-medium rounded-md #{current_status == 'all' ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
  </div>

  <!-- Platform filters -->
  <div class="mb-6 flex gap-3">
    <%= link_to "All", conversations_path(status: current_status),
      class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:platform].blank? ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
    <% Conversation.platforms.each_key do |platform| %>
      <%= link_to platform.upcase == "WHATSAPP" ? "WhatsApp" : platform.capitalize,
        conversations_path(platform: platform, status: current_status),
        class: "px-3 py-1.5 text-sm font-medium rounded-md #{params[:platform] == platform ? 'bg-slate-700 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}" %>
    <% end %>
  </div>

  <% if @conversations.any? %>
    <%= turbo_stream_from "conversations" %>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl overflow-hidden divide-y divide-slate-100" id="conversation-list">
      <% @conversations.each do |conversation| %>
        <%= render "conversations/conversation_row", conversation: conversation %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white ring-1 ring-slate-200 rounded-xl p-12 text-center">
      <p class="text-slate-500">No conversations yet.</p>
      <p class="text-sm text-slate-400 mt-1">Messages will appear here once the Meta webhook is connected.</p>
    </div>
  <% end %>
</div>
