# QA secrets — loaded automatically when deploying with: kamal setup -d qa / kamal deploy -d qa

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

RAILS_MASTER_KEY=$(cat config/master.key)

DATABASE_URL=$DATABASE_URL_CRM_QA

# Google OAuth credentials
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET

# Webhook token for verifying incoming requests
WEBHOOK_TOKEN=$WEBHOOK_TOKEN

# Build info for deployment tracking
BUILD_INFO=$(./scripts/generate_build_info.sh)
